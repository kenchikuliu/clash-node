def main():
    """主函数"""
    if len(sys.argv) < 2:
        cmd_list()
        return

    command = sys.argv[1]

    # 数字命令（切换节点）
    if command.isdigit():
        cmd_switch(int(command))
    elif command == "list" or command == "ls":
        cmd_list()
    elif command == "status" or command == "st":
        cmd_status()
    elif command == "test":
        if len(sys.argv) > 2 and sys.argv[2].isdigit():
            cmd_test(int(sys.argv[2]))
        else:
            cmd_test()
    elif command == "best":
        cmd_best()
    elif command == "tune":
        subcommand = sys.argv[2] if len(sys.argv) > 2 else None
        cmd_tune(subcommand)
    elif command == "add":
        if len(sys.argv) < 3:
            print_error("请提供 VMess URL")
            print_info("用法: clash-node add vmess://...")
        else:
            cmd_add_vmess(sys.argv[2])
    elif command == "help" or command == "-h" or command == "--help":
        cmd_help()
    else:
        print_error(f"未知命令: {command}")
        print_info("使用 'clash-node help' 查看帮助")
        sys.exit(1)

if __name__ == "__main__":
    try:
        main()
    except KeyboardInterrupt:
        print(f"\n{Colors.YELLOW}已取消{Colors.RESET}")
        sys.exit(0)
    except Exception as e:
        print_error(f"发生错误: {e}")
        sys.exit(1)
